{
  "name": "job-apply-agent",
  "version": "0.1.0",
  "description": "Autonomous US job-application system (Lane A) — sourcing, scoring, tailoring, guarded apply, tracking.",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "source": "tsx src/cli.ts source",
    "score": "tsx src/cli.ts score",
    "report": "tsx src/cli.ts report",
    "orchestrate": "tsx src/orchestrator.ts",
    "ingest:aiapply": "tsx src/cli.ts ingest aiapply",
    "ingest:jobright": "tsx src/cli.ts ingest jobright",
    "db:init": "tsx src/cli.ts db init",
    "mcp": "tsx src/mcp/server.ts",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.7.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
